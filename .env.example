# Kup 환경변수 템플릿 — 복사: `cp .env.example .env.local`
# ⚠️ .env.local / .env.* 는 .gitignore 됨. 실제 키 값은 절대 커밋 금지.
#    이 파일엔 "빈 값/플레이스홀더"만 둔다(시크릿 X).
#
# 현재 단계 = "화면 먼저"(워크스페이스 데이터는 로컬 파일DB .data, 로그인만 Supabase).
# 아래 ①②만 채우면 로컬에서 로그인+워크스페이스가 돈다. ③④는 개인/나중.

# ── ① 로컬 Supabase (로그인) — Docker 필요 ────────────────────────────
# 팀원: Docker 실행 → `npx supabase start` → 출력된 URL/키를 그대로 붙여넣기.
#       키는 로컬 표준 기본값이라 팀 전체 동일(비밀 아님). 마이그레이션은 자동 적용됨.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=        # ← `supabase start` 출력의 anon key
SUPABASE_SERVICE_ROLE_KEY=            # ← `supabase start` 출력의 service_role key

# 워크스페이스 데이터 저장 백엔드:
#   (미설정, 기본) 로컬 파일 .data/db.json — 로컬 개발·npm run gen
#   supabase        Supabase app_state(JSONB) — 서버리스/배포(Vercel)용. FS 휘발 회피.
#                   설정 시 마이그레이션 0005_app_state 적용 필요(supabase db push).
# KUP_DB_BACKEND=supabase

# ── ② 구글 로그인 (선택) ──────────────────────────────────────────────
# supabase/config.toml 이 이 두 값을 참조. 팀 공용 1세트를 공유받아 입력(개별 발급 불필요).
# 비우면 구글 버튼만 안 되고 이메일/비번 로그인은 정상 동작.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── ③ LLM 키 — 개인별(각자 자기 키) ──────────────────────────────────
# 없으면 AI 생성이 템플릿(mock)으로 자동 폴백 → 화면은 다 돌아감.
# ⚠️ 실제 키는 이 파일이 아니라 .env.local 에 붙여넣는다(이 파일은 커밋됨 → 빈 값만).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
# 생성 파이프라인(generateDeck: 기획→카피→검수) 공급자 선택. 미설정=mock(키 불필요).
# 실제 Claude 검수를 켜려면 anthropic 으로 두고 ANTHROPIC_API_KEY 를 채운다.
LLM_PROVIDER=mock                      # mock | anthropic
OPENAI_API_KEY=                       # ← 발급받은 OpenAI 키(sk-...) 붙여넣기
GOOGLE_API_KEY=                        # ← Google Gemini 키(AI... , aistudio.google.com 발급) 붙여넣기

# ── ④ 인스타 연동 (OAuth) — "인스타로 로그인" 버튼을 쓰려면 필요 ──────────
# Meta 앱 1세트(서비스 전역). 사용자별 IG 토큰은 env가 아니라 OAuth 로 받아 DB에 봉인 저장.
# 비우면 accounts 화면의 "인스타로 로그인" 버튼은 503으로 막히고, 테스터(시뮬)만 동작한다.
#   준비: developers.facebook.com → 앱 생성 → "Instagram API" 제품 추가 →
#         Instagram 로그인 설정에서 ▸ 클라이언트 ID/시크릿 확인,
#         ▸ "유효한 OAuth 리디렉션 URI"에 아래 IG_OAUTH_REDIRECT_URI 와 똑같은 값 등록.
#   필요 권한(스코프): instagram_business_basic / _content_publish / _manage_comments
#                      / _manage_messages / _manage_insights  (앱 심사 전엔 테스터 계정만 가능)
# IG_APP_ID=                          # Meta 앱의 Instagram 앱 ID(클라이언트 ID)
# IG_APP_SECRET=                      # Instagram 앱 시크릿
# IG_OAUTH_REDIRECT_URI=http://localhost:3000/api/ig/oauth/callback   # 등록값과 정확히 일치
# IG_WEBHOOK_VERIFY_TOKEN=            # 댓글→DM 웹훅 검증 토큰(임의 문자열, 다음 단계)
# TOKEN_ENCRYPTION_KEY=               # IG 토큰 봉인 대칭키(임의 문자열). 없으면 평문 저장(로컬만)

# ── ⑤ 발행/관측 (나중/선택) ──────────────────────────────────────────
# REDIS_URL=                          # BullMQ 워커(예약/cron)
# PUBLIC_BASE_URL=                    # 인스타 발행용 공개 https 주소(로컬은 ngrok 등)
# IG_GRAPH_VERSION=v21.0              # Meta Graph API 버전(기본값)
# SENTRY_DSN=                         # 관측(현재 스텁)
