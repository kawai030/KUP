# KUP 환경변수 예시 — 이 파일을 .env.local 로 복사해 채우세요.

# Claude (Anthropic) API 키 — 없으면 템플릿 기반 생성으로 자동 대체됩니다.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# 세션 서명 비밀키 (운영 시 무작위 문자열로 교체)
SESSION_SECRET=change-me-in-production

# ── 실제 인스타 발행용 ───────────────────────────────────────────────
# 인스타는 image_url(공개 주소)로 이미지를 가져갑니다. 따라서 이 앱이 외부에서
# 접근 가능한 공개 URL이어야 해요. 로컬이면 ngrok 등 터널을 띄우고 그 https 주소를 넣으세요.
#   예) ngrok http 3000  →  https://xxxx.ngrok-free.app
PUBLIC_BASE_URL=

# (선택) Meta Graph API 버전. 기본 v21.0
IG_GRAPH_VERSION=v21.0
# 토큰·IG User ID는 워크스페이스 > 연동 인스타 계정에서 계정별로 입력합니다.
