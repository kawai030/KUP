{
  "name": "spike-bullmq",
  "version": "0.1.0",
  "private": true,
  "description": "BullMQ durability spike — 워커가 죽었다 살아나도 예약 잡이 살아남아 실행되는가",
  "type": "module",
  "scripts": {
    "redis:up": "docker compose up -d",
    "redis:down": "docker compose down",
    "redis:reset": "docker compose down -v",
    "worker": "node src/worker.js",
    "schedule": "node src/schedule.js",
    "cron": "node src/cron.js",
    "status": "node src/status.js"
  },
  "dependencies": {
    "bullmq": "^5.34.0",
    "ioredis": "^5.4.2"
  }
}
